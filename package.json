{
  "name": "skybox-studio-runtime",
  "version": "0.1.0",
  "description": "Three.js runtime for live and baked Skybox Studio manifests.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run test && npm run build && npm run pack:dry-run",
    "test": "vitest run"
  },
  "peerDependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "color-blend": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
